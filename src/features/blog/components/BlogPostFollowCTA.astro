---
import type { Language } from '@/i18n/config';
import type { TranslationDictionary } from '@/shared/i18n/types';
import { getTranslationDictionary } from '@/shared/i18n/types';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t: TranslationDictionary = getTranslationDictionary(lang);

const links = [
  {
    id: 'github',
    href: 'https://github.com/BubblePtr',
    label: t['blog.post.followCta.github'],
  },
  {
    id: 'twitter',
    href: 'https://twitter.com/ninthbit_ai',
    label: t['blog.post.followCta.twitter'],
  },
] as const;
---

<aside
  class="mx-auto w-full max-w-xl mt-16"
  aria-label={lang === 'zh' ? '关注作者' : 'Follow the author'}
>
  <div
    class="relative isolate overflow-hidden rounded-2xl border border-zinc-200/70 bg-[oklch(96.2%_0.01_58)] px-6 py-5 sm:px-7 sm:py-6 shadow-[0_1px_2px_rgba(24,24,27,0.04)] dark:border-zinc-800/80 dark:bg-zinc-900/55 dark:shadow-none"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(249,115,22,0.07),transparent_55%)] dark:bg-[radial-gradient(ellipse_at_top_right,rgba(249,115,22,0.1),transparent_55%)]"
    >
    </div>

    <div class="relative">
      <h2
        class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-2"
        style={lang === 'zh' ? 'font-family: var(--font-serif)' : 'font-family: var(--font-serif-en)'}
      >
        {t['blog.post.followCta.title']}
      </h2>
      <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-5 leading-relaxed">
        {t['blog.post.followCta.body']}
      </p>
      <div class="flex flex-wrap gap-3">
        {
          links.map(({ id, href, label }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="relative z-10 inline-flex items-center gap-2 rounded-full border border-zinc-200/90 bg-white/70 px-3.5 py-1.5 text-sm font-medium text-zinc-700 transition-colors hover:border-zinc-300 hover:text-zinc-900 dark:border-zinc-700/90 dark:bg-zinc-950/35 dark:text-zinc-300 dark:hover:border-zinc-600 dark:hover:text-zinc-100"
            >
              {id === 'github' ? (
                <svg
                  aria-hidden="true"
                  viewBox="0 0 24 24"
                  width="16"
                  height="16"
                  fill="currentColor"
                >
                  <path d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z" />
                </svg>
              ) : (
                <svg
                  aria-hidden="true"
                  viewBox="0 0 24 24"
                  width="16"
                  height="16"
                  fill="currentColor"
                >
                  <path d="M17.6874 3.0625L12.6907 8.77425L8.37045 3.0625H2.11328L9.58961 12.8387L2.50378 20.9375H5.53795L11.0068 14.6886L15.7863 20.9375H21.8885L14.095 10.6342L20.7198 3.0625H17.6874ZM16.6232 19.1225L5.65436 4.78217H7.45745L18.3034 19.1225H16.6232Z" />
                </svg>
              )}
              <span>{label}</span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</aside>
