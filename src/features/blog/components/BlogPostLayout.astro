---
import type { CollectionEntry } from 'astro:content';
import type { Language } from '@/i18n/config';
import type { TranslationDictionary } from '@/shared/i18n/types';
import { getTranslationDictionary } from '@/shared/i18n/types';
import { Image } from 'astro:assets';
import BaseHead from '@/components/BaseHead.astro';
import SiteHeader from '@/shared/components/navigation/SiteHeader.client';
import SiteFooter from '@/shared/components/layout/SiteFooter.client';
import ArticleToc from '@/features/blog/components/ArticleToc.astro';
import type { TocHeading } from '@/features/blog/toc';
import GiscusComments from '@/features/blog/components/GiscusComments.client';
import BlogColophon from '@/features/blog/components/BlogColophon.astro';
import BlogPostFollowCTA from '@/features/blog/components/BlogPostFollowCTA.astro';
import BlogImageLightbox from '@/features/blog/components/BlogImageLightbox.astro';
import { resolveBlogAuthor } from '@/features/blog/authors';
import { isIndieDevWeeklyPost } from '@/features/blog/series';
import { RiCalendarLine, RiTimeLine } from '@remixicon/react';
import { withTrailingSlash } from '@/shared/urls';


type Props = CollectionEntry<'blog'>['data'] & {
  slug?: string;
  ogSlug?: string;
  readTimeMinutes?: number;
  localizedPaths?: Partial<Record<Language, string>>;
  tocHeadings?: TocHeading[];
};

const {
  title,
  description,
  pubDate,
  heroImage,
  heroImageCredit,
  author,
  tags,
  slug,
  ogSlug,
  readTimeMinutes,
  localizedPaths,
  tocHeadings = [],
} = Astro.props;

const showIndieDevWeeklyColophon = isIndieDevWeeklyPost(tags);

const lang: Language = Astro.url.pathname.startsWith('/zh/') ? 'zh' : 'en';
const t: TranslationDictionary = getTranslationDictionary(lang);

const currentPath = slug
  ? lang === 'zh'
    ? withTrailingSlash(`/zh/blog/${slug}`)
    : withTrailingSlash(`/blog/${slug}`)
  : lang === 'zh'
    ? '/zh/blog/'
    : '/blog/';

const formattedDate = pubDate.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const readTimeLabel =
  lang === 'zh'
    ? `${Math.max(1, readTimeMinutes ?? 5)} 分钟阅读`
    : `${Math.max(1, readTimeMinutes ?? 5)} min read`;

const sectionLabel = 'WORK INSIGHTS';
const resolvedAuthor = resolveBlogAuthor(author, lang);
---

<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} slug={ogSlug} />
  </head>

  <body class="bg-[oklch(98%_0.006_60)] dark:bg-zinc-950 text-zinc-800 dark:text-zinc-200 transition-colors duration-500 antialiased font-sans">
    <SiteHeader client:load currentPath={currentPath} lang={lang} t={t} localizedPaths={localizedPaths} />
    <div class="px-[var(--page-gutter)]" aria-hidden="true">
      <div class="mx-[var(--page-bleed)] section-rule"></div>
    </div>

    <main class="px-[var(--page-gutter)] py-12 sm:py-20 relative z-10">
      <article data-blog-article>
        <header class="mx-auto w-full max-w-3xl mb-12">
          <div class="flex items-center justify-between gap-6 mb-6">
            <div>
              <p class="kicker mb-6">{sectionLabel}</p>
              <div class="flex items-center gap-4 text-xs font-mono text-zinc-400 uppercase tracking-wider">
                <span class="flex items-center gap-1">
                  <RiTimeLine size={12} /> {readTimeLabel}
                </span>
                <span class="w-px h-3 bg-zinc-200 dark:bg-zinc-800"></span>
                <span class="flex items-center gap-1">
                  <RiCalendarLine size={12} />
                  {formattedDate}
                </span>
              </div>
            </div>
            {showIndieDevWeeklyColophon && (
              <BlogColophon lang={lang} width={180} class="shrink-0 hidden sm:flex" />
            )}
          </div>

          {showIndieDevWeeklyColophon && (
            <BlogColophon lang={lang} width={160} class="sm:hidden mb-6" />
          )}

          <h1
            class="text-[2.2rem] sm:text-[2.9rem] font-semibold text-zinc-900 dark:text-zinc-100 leading-[1.2] mb-8"
            style={`view-transition-name: bt-${(slug ?? '').replace(/[^a-zA-Z0-9]/g, '-')}; ${lang === 'zh' ? 'font-family: var(--font-serif)' : 'font-family: var(--font-serif-en)'}`}
          >
            {title}
          </h1>
        </header>

        {
          heroImage && (
            <figure class="mb-12" data-blog-hero-image>
              <div class="relative aspect-[16/10] sm:aspect-[21/9] w-full overflow-hidden border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900">
                <Image src={heroImage} alt={title} class="object-cover w-full h-full" inferSize loading="eager" />
              </div>
              {heroImageCredit && (
                <figcaption class="mt-2 text-right text-xs text-zinc-400 dark:text-zinc-500">
                  {lang === 'zh' ? '图片来源：' : 'Image: '}
                  <a
                    href={heroImageCredit.authorUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline decoration-zinc-300 underline-offset-2 hover:text-zinc-600 dark:hover:text-zinc-300"
                  >
                    {heroImageCredit.author}
                  </a>
                  {lang === 'zh' ? ' / ' : ' on '}
                  <a
                    href={heroImageCredit.sourceUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="underline decoration-zinc-300 underline-offset-2 hover:text-zinc-600 dark:hover:text-zinc-300"
                  >
                    {heroImageCredit.source}
                  </a>
                </figcaption>
              )}
            </figure>
          )
        }

        <section class="mx-auto w-full max-w-xl">
          <p
            class="text-xl sm:text-2xl leading-relaxed text-zinc-900 dark:text-zinc-100 mb-7"
            style={lang === 'zh' ? 'font-family: var(--font-serif)' : 'font-family: var(--font-serif-en)'}
          >
            {description}
          </p>

          <div class="flex w-full items-center gap-4">
            <div class="inline-flex items-center gap-3">
              <img
                src={resolvedAuthor.avatar}
                alt={resolvedAuthor.name}
                class="h-8 w-8 rounded-full object-cover border border-zinc-200 dark:border-zinc-700"
                loading="lazy"
              />
              <div>
                <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 leading-none mb-0.5">{resolvedAuthor.name}</p>
                <p class="text-xs text-zinc-500 dark:text-zinc-400">{resolvedAuthor.title}</p>
              </div>
            </div>
          </div>

          <div aria-hidden="true" class="-mx-[calc(50vw-50%)] section-rule mt-6" />
        </section>

        <div class="flex justify-center">
          <div class="article-body-shell relative w-full max-w-xl">
            <ArticleToc lang={lang} headings={tocHeadings} />
            <div class="article-prose prose">
              <slot />
            </div>
          </div>
        </div>

        <BlogPostFollowCTA lang={lang} />
      </article>

      <section class="mx-auto w-full max-w-xl mt-16 pt-12">
        <div aria-hidden="true" class="-mx-[calc(50vw-50%)] section-rule mb-12" />
        <h2
          class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100 mb-8"
          style={lang === 'zh' ? 'font-family: var(--font-serif)' : 'font-family: var(--font-serif-en)'}
        >
          {lang === 'zh' ? '评论' : 'Comments'}
        </h2>
        <GiscusComments client:load lang={lang} />
      </section>
    </main>

    <div class="px-[var(--page-gutter)]" aria-hidden="true">
      <div class="mx-[var(--page-bleed)] section-rule"></div>
    </div>
    <SiteFooter client:visible lang={lang} t={t} />
    <BlogImageLightbox lang={lang} />
  </body>
</html>
