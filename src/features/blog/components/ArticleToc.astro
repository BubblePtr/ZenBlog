---
import type { Language } from '@/i18n/config';
import type { TocHeading } from '@/features/blog/toc';
import { shouldShowToc } from '@/features/blog/toc';
import CrispToc from '@/shared/components/navigation/CrispToc.client';

interface Props {
  lang: Language;
  headings: TocHeading[];
}

const { lang, headings } = Astro.props;

if (!shouldShowToc(headings)) {
  return null;
}

const title = lang === 'zh' ? '目录' : 'On this page';
const items = headings.map((heading) => ({
  id: heading.slug,
  label: heading.text,
}));
---

<aside class="article-toc-aside">
  <CrispToc
    client:load
    items={items}
    ariaLabel={title}
    showThemeBar={false}
    showFooter={false}
    scrollSpy
    soundEnabled={false}
    class="article-toc"
  />
</aside>

<script>
  import {
    initArticleCrispTocLayout,
    teardownArticleCrispTocLayout,
  } from '@/features/blog/article-crisp-toc.client';

  initArticleCrispTocLayout();
  document.addEventListener('astro:page-load', initArticleCrispTocLayout);
  document.addEventListener('astro:before-swap', teardownArticleCrispTocLayout);
</script>
