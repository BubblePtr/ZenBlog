---
import type { TranslationDictionary } from '@/shared/i18n/types';
import type { Language } from '@/i18n/config';

interface Props {
  t: TranslationDictionary;
  lang: Language;
  class?: string;
}

const { t, lang, class: className } = Astro.props;
const isZh = lang === 'zh';
---

<section
  class:list={[
    'pb-[clamp(2.5rem,5vw,4rem)]',
    className,
  ]}
  aria-label={isZh ? '自我介绍' : 'Introduction'}
>
  <p
    class="max-w-[58ch] whitespace-pre-line text-[1.0625rem] leading-[1.85] font-light text-[var(--color-text-primary)]"
  >
    {t['about.identity.statement']}
  </p>
</section>
