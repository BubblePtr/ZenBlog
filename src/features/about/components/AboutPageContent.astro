---
import type { TranslationDictionary } from '@/shared/i18n/types';
import type { Language } from '@/i18n/config';
import IdentityBand from '@/features/about/components/IdentityBand.astro';
import PersonalDetails from '@/features/about/components/PersonalDetails.astro';

interface Props {
  t: TranslationDictionary;
  lang: Language;
}

const { t, lang } = Astro.props;
---

<div class="px-[var(--page-gutter)] relative z-10">
  <IdentityBand t={t} lang={lang} />

  <PersonalDetails t={t} lang={lang} />
</div>
