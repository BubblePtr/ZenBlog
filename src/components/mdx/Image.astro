---
import { Image as AstroImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src?: string | ImageMetadata;
  alt?: string;
}

const { src = '', alt = '' } = Astro.props;

const contentImages = import.meta.glob<ImageMetadata>(
  '/src/content/blog/images/*.{png,jpg,jpeg,webp,gif}',
  { eager: true, import: 'default' },
);

function isImageMetadata(value: unknown): value is ImageMetadata {
  return typeof value === 'object' && value !== null && 'src' in value && 'width' in value;
}

function resolveRelativeContentImage(path: string): ImageMetadata | undefined {
  if (!path.startsWith('../images/')) {
    return undefined;
  }

  const filename = path.slice('../images/'.length);
  const entry = Object.entries(contentImages).find(([key]) => key.endsWith(`/${filename}`));

  return entry?.[1];
}

let resolvedSrc: string | ImageMetadata = src;

if (typeof src === 'string' && src.startsWith('../images/')) {
  const imported = resolveRelativeContentImage(src);
  if (imported) {
    resolvedSrc = imported;
  }
}

const canUseAstroImage =
  isImageMetadata(resolvedSrc) ||
  (typeof resolvedSrc === 'string' && /^https?:\/\//.test(resolvedSrc));
---

{
  canUseAstroImage ? (
    <AstroImage src={resolvedSrc} alt={alt} inferSize class="w-full h-auto" />
  ) : (
    <img src={typeof src === 'string' ? src : ''} alt={alt} class="w-full h-auto" loading="lazy" decoding="async" />
  )
}
