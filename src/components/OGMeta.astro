---
/**
 * ZenBlog — OG meta tags component
 *
 * Drop inside <head> in BaseHead.astro:
 *   <OGMeta title={title} description={description} slug={slug} />
 *
 * Props:
 *   title        — page title (string)
 *   description  — page description (string, optional)
 *   slug         — blog post slug (string | undefined)
 *                  Used to set og:type to "article" when present.
 *   type         — "website" | "article" (default: auto-detected from slug)
 */

import { SITE_URL } from '../consts';

interface Props {
  title: string;
  description?: string;
  slug?: string;
  type?: 'website' | 'article';
}

const {
  title,
  description = 'Writing about engineering, visual minimalism, and the tools I use to think.',
  slug,
  type = slug ? 'article' : 'website',
} = Astro.props;

const ogImage = `${SITE_URL}/og/brand.png`;

const pageTitle = slug ? `${title} — Kieran Zhang` : title;
const descriptionText = description.trim();
const descriptionSuffix = /[\u3400-\u9fff]/.test(descriptionText)
  ? ' 在 Kieran Zhang 的个人网站继续阅读关于软件工程、AI 产品、独立项目实践、摄影记录、工具方法、公开幕后复盘与长期思考的双语笔记。'
  : ' Read more essays, project notes, photography, and practical engineering reflections from Kieran Zhang.';
const metaDescription =
  [...descriptionText].length >= 80 ? descriptionText : `${descriptionText}${descriptionSuffix}`;
---

<!-- Primary -->
<title>{pageTitle}</title>
<meta name="description" content={metaDescription} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={metaDescription} />
<meta property="og:url" content={Astro.url} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="Kieran Zhang" />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@ninthbit_ai" />
<meta name="twitter:creator" content="@ninthbit_ai" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={metaDescription} />
<meta name="twitter:image" content={ogImage} />
