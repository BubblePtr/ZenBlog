---
/**
 * ZenBlog — OG meta tags component
 *
 * Drop inside <head> in BaseHead.astro:
 *   <OGMeta title={title} description={description} slug={slug} />
 *
 * Props:
 *   title        — page title (string)
 *   description  — page description (string, optional)
 *   slug         — blog post slug (string | undefined)
 *                  If provided, uses the dynamic per-post OG image.
 *                  If omitted, falls back to the static brand image.
 *   type         — "website" | "article" (default: auto-detected from slug)
 */

interface Props {
  title: string;
  description?: string;
  slug?: string;
  type?: 'website' | 'article';
}

const {
  title,
  description = 'Writing about engineering, visual minimalism, and the tools I use to think.',
  slug,
  type = slug ? 'article' : 'website',
} = Astro.props;

const siteUrl = 'https://kieranzhang.dev';
const ogImage = slug
  ? `${siteUrl}/og/${slug}.png`
  : `${siteUrl}/og/brand.png`;

const pageTitle = slug ? `${title} — Kieran Zhang` : title;
---

<!-- Primary -->
<title>{pageTitle}</title>
<meta name="description" content={description} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={Astro.url} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="Kieran Zhang" />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
