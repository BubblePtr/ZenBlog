---
import "../styles/global.css";
// 1. 引入 ClientRouter (Astro 5.0+)
import { ClientRouter } from "astro:transitions";
import OGMeta from "@/components/OGMeta.astro";

interface Props {
  title: string;
  description: string;
  slug?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, slug } = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />
<!-- 品牌色定义 (移动端浏览器顶栏颜色) -->
<!-- 使用中性灰色 #71717a (Tailwind zinc-500) -->
<meta name="theme-color" content="#71717a" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<OGMeta title={title} description={description} slug={slug} />

<script
  defer
  src="https://cloud.umami.is/script.js"
  data-website-id="d7c290cc-3033-4ef1-8df1-f1a6484d9a08"></script>

<!-- 字体系统 -->
<!-- Noto Serif SC 用于中文文章标题 -->
<!-- Shippori Mincho 用于英文文章标题 -->
<!-- 配置文件：src/styles/typography.css -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<!-- CDN：头像、摄影图片 -->
<link rel="preconnect" href="https://cdn.ninthbit.org" />
<link
  rel="preload"
  href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@600;700&family=Shippori+Mincho:wght@400;600&display=swap"
  as="style"
  onload="this.onload=null;this.rel='stylesheet'"
/>
<noscript>
  <link
    href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@600;700&family=Shippori+Mincho:wght@400;600&display=swap"
    rel="stylesheet"
  />
</noscript>

<!-- 2. 启用视图过渡路由 -->
<ClientRouter />

<!-- 主题初始化脚本：防止闪烁，在页面渲染前应用主题 -->
<script is:inline>
  // 应用主题的函数
  function applyTheme() {
    const theme = localStorage.getItem('theme');
    if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  }

  // 页面加载时应用主题
  applyTheme();

  // Astro View Transitions: 页面切换后重新应用主题
  document.addEventListener('astro:after-swap', applyTheme);
</script>
