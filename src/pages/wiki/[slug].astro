---
import StaticRedirect from '@/shared/components/navigation/StaticRedirect.astro';
import { getWikiStaticPaths, extractSlug } from '@/features/wiki/server/queries.server';

export async function getStaticPaths() {
  return getWikiStaticPaths();
}

const entry = Astro.props;
const slug = extractSlug(entry.id);
---

<StaticRedirect target={`/zh/wiki/${slug}/`} title="Redirecting to LLM-WIKI" />
