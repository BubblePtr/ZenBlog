---
import { SITE_TITLE } from '@/consts';
import { BlogListSection } from '@/features/blog';
import { getBlogListByLang, getBubbleDiarySummary } from '@/features/blog/server';
import PageShell from '@/shared/components/layout/PageShell.astro';
import { getTranslationDictionary } from '@/shared/i18n/types';

const lang = 'en' as const;
const t = getTranslationDictionary(lang);
const [posts, bubbleDiary] = await Promise.all([
  getBlogListByLang(lang),
  getBubbleDiarySummary(),
]);
---

<PageShell
  lang={lang}
  title={`${t['nav.blog']} | ${SITE_TITLE}`}
  description={t['blog.description']}
  currentPath="/blog"
  mainClass="max-w-[84rem] mx-auto px-6 py-12 sm:py-20 relative z-10"
>
  <BlogListSection client:load posts={posts} bubbleDiary={bubbleDiary} lang={lang} t={t} />
</PageShell>
