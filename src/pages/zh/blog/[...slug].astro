---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import BlogPostLayout from '@/features/blog/components/BlogPostLayout.astro';
import { mdxComponents } from '@/components/mdx/components';
import {
  extractBlogSlug,
  getBlogLocalizedPaths,
  getBlogStaticPathsByLang,
  getReadTime,
  getSeriesPosition,
} from '@/features/blog/server';

const lang = 'zh' as const;

export async function getStaticPaths() {
  return getBlogStaticPathsByLang('zh');
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props as Props;
const { Content } = await render(post);
const currentSlug = extractBlogSlug(post.id, lang);
const ogSlug = post.id.replace(/\.[^/.]+$/, '');
const readTimeMinutes = getReadTime(post.body ?? '', lang);
const localizedPaths = await getBlogLocalizedPaths(post);
const seriesPosition = await getSeriesPosition(post);
---

<BlogPostLayout
  {...post.data}
  slug={currentSlug}
  ogSlug={ogSlug}
  readTimeMinutes={readTimeMinutes}
  seriesNo={seriesPosition?.no}
  localizedPaths={localizedPaths}
>
  <Content components={mdxComponents} />
</BlogPostLayout>
