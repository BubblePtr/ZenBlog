---
import { SITE_TITLE } from '@/consts';
import { WikiList } from '@/features/wiki';
import { getAllWikiEntries, buildGraphData } from '@/features/wiki/server/queries.server';
import { KnowledgeGraph } from '@/features/wiki';
import PageShell from '@/shared/components/layout/PageShell.astro';
import { getTranslationDictionary } from '@/shared/i18n/types';

const lang = 'zh' as const;
const t = getTranslationDictionary(lang);
const entries = await getAllWikiEntries();
const graphData = await buildGraphData();
---

<PageShell
  lang={lang}
  title={`${t['nav.wiki']} | ${SITE_TITLE}`}
  description="量化交易与预测市场的知识库"
  currentPath="/zh/wiki"
  mainClass="max-w-[84rem] mx-auto px-6 py-12 sm:py-20 relative z-10"
>
  <div class="mb-12">
    <p class="text-xs font-medium uppercase tracking-[0.18em] text-zinc-500 dark:text-zinc-400 mb-4">
      KNOWLEDGE BASE
    </p>
    <h1
      class="text-3xl sm:text-4xl font-semibold text-zinc-900 dark:text-zinc-100 mb-3"
      style="font-family: var(--font-serif)"
    >
      {t['nav.wiki']}
    </h1>
    <p class="text-zinc-500 dark:text-zinc-400 text-sm max-w-xl">
      量化交易与 Polymarket 预测市场的知识图谱。基于 Karpathy 的 LLM Wiki 方法论构建，持续更新中。
    </p>
  </div>

  <div class="mb-16">
    <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-4 font-serif">
      知识图谱
    </h2>
    <KnowledgeGraph client:load graphData={graphData} />
  </div>

  <div aria-hidden="true" class="-mx-[calc(50vw-50%)] section-rule mb-12" />

  <WikiList entries={entries} />
</PageShell>
